# --- Solana RPC ---
# Use a paid RPC (Helius / QuickNode / Triton). Free RPCs disable
# getProgramAccounts which is required for snapshotting the infected.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# --- Wallets ---
# CREATOR_WALLET = the pump.fun creator wallet for $VIRUS. Claims fees.
CREATOR_WALLET_PRIVATE_KEY=base58_secret_key
# Optional: separate buyer/sender wallet (the wallet that holds SOL between
# claim and payout, signs the 2-hop send). Leave blank to use the creator
# wallet for both roles (single-wallet mode).
# BUYER_WALLET_PRIVATE_KEY=base58_secret_key

# Where the non-winner half of each claim goes (marketing budget).
# If blank, defaults to the creator wallet (which is fine — dev manages it).
# MARKETING_WALLET=pubkey_base58

# --- Token ---
# Leave VIRUS_MINT=auto to have the bot watch the creator wallet and adopt
# whichever pump.fun token it launches next.
VIRUS_MINT=auto
MINT_WATCH_POLL_SECONDS=20

# --- PumpPortal (https://pumpportal.fun) ---
# Used for claiming creator fees. Optional Lightning API key for server-side
# signing — leave blank for local signing.
PUMPPORTAL_API_KEY=

# --- Cycle settings ---
CYCLE_INTERVAL_SECONDS=300           # 300 = 5 min
SNAPSHOT_LEAD_SECONDS=10             # snapshot the infected this many seconds before the spin
MIN_PRIZE_SOL=0.005                  # skip cycle if winner slice falls below this

# 3-way split of every claim — must sum to 100.
WINNER_PERCENT=50                    # % paid to the winner
MARKETING_PERCENT=30                 # % to marketing wallet (or buyer wallet if MARKETING_WALLET unset)
BUYBACK_PERCENT=20                   # % spent buying back $VIRUS to incinerate
BUYBACK_SLIPPAGE_PCT=10              # pump.fun slippage tolerance for the buyback
MIN_BUYBACK_SOL=0.002                # skip buyback this cycle if slice < this (dust filter)

# Belt-and-suspenders ceiling: bot may never spend more than this many SOL on
# a single winner payout, regardless of how big a single claim was. Default 5.
MAX_SOL_PER_CYCLE=5
PRIORITY_FEE=0.0005                  # SOL of priority fee on each tx

# --- Wheel / eligibility ---
MIN_HOLDER_BALANCE=1                 # ignore wallets with < this many $VIRUS
# Auto-exclude any wallet holding more than this % of total supply
# (catches LP / bonding curve / treasury automatically without an address).
MAX_HOLDER_SHARE_PCT=20
# Comma-separated wallets to exclude from the wheel (LP, dev, treasury, etc.)
EXCLUDE_WALLETS=
MAX_HOLDERS_ON_WHEEL=200             # cap shown on the wheel (rest grouped into "OTHERS")

# --- State persistence ---
# On Railway / any host with a persistent volume, point this at the volume
# mount path (e.g. /data). Falls back to ./data locally. Stats survive deploys.
# STATE_DIR=/data

# --- Dashboard ---
PORT=3000
LOG_LEVEL=info
